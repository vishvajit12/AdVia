# =====================================================================
# AdVia — Root .gitignore
# =====================================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Environment files (never commit secrets)
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Build output
frontend/dist/
frontend/build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor/OS files
.DS_Store
.vscode/
.idea/
*.swp

# MySQL local data (if storing dumps)
*.sql.bak
